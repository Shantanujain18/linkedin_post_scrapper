{
  "manifest_version": 3,
  "name": "ReachPod",
  "version": "2.0.0",
  "description": "Export expanded LinkedIn post search results to CSV from the current Chrome profile.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ReachPod",
    "default_popup": "popup.html"
  }
}
